{
  "uiTreePath": ".arkpilot/designs/ui-tree.json",
  "dataModel": {
    "entities": [
      {
        "name": "Pet",
        "fields": {
          "id": "string (uuid)",
          "name": "string",
          "avatar": "string (rawfile path or empty)",
          "breed": "string",
          "birthday": "string (yyyy-mm-dd)",
          "gender": "'male' | 'female' | 'unknown'",
          "neutered": "boolean",
          "baseWeightKg": "number | undefined",
          "chipId": "string",
          "createdAt": "number (timestamp ms)"
        }
      },
      {
        "name": "Record",
        "fields": {
          "id": "string (uuid)",
          "petId": "string",
          "category": "'food' | 'toilet' | 'weight' | 'medicine'",
          "time": "number (timestamp ms)",
          "foodType": "string | undefined",
          "foodAmount": "string | undefined",
          "toiletType": "'pee' | 'poop' | 'both' | undefined",
          "toiletStatus": "'normal' | 'soft' | 'hard' | 'diarrhea' | 'blood' | undefined",
          "weightValueKg": "number | undefined",
          "medicineName": "string | undefined",
          "medicineDose": "string | undefined",
          "notes": "string",
          "createdAt": "number (timestamp ms)"
        }
      },
      {
        "name": "VaccineDeworm",
        "fields": {
          "id": "string (uuid)",
          "petId": "string",
          "type": "'vaccine' | 'deworm'",
          "name": "string",
          "date": "number (timestamp ms)",
          "nextDate": "number (timestamp ms)",
          "clinic": "string",
          "createdAt": "number (timestamp ms)"
        }
      },
      {
        "name": "MedicalRecord",
        "fields": {
          "id": "string (uuid)",
          "petId": "string",
          "date": "number (timestamp ms)",
          "hospital": "string",
          "doctor": "string",
          "diagnosis": "string",
          "prescription": "string",
          "cost": "number | undefined",
          "attachments": "string[] (rawfile/uri placeholders)",
          "createdAt": "number (timestamp ms)"
        }
      },
      {
        "name": "FamilyMember",
        "fields": {
          "id": "string (uuid)",
          "name": "string",
          "role": "'admin' | 'collaborator'",
          "inviteCode": "string | undefined",
          "isSelf": "boolean"
        }
      },
      {
        "name": "Reminder",
        "fields": {
          "id": "string (uuid)",
          "petId": "string",
          "petName": "string",
          "type": "'vaccine' | 'deworm' | 'medicine' | 'weight' | 'custom'",
          "title": "string",
          "dueDate": "number (timestamp ms)",
          "done": "boolean"
        }
      },
      {
        "name": "AppSettings",
        "fields": {
          "weightUnit": "'kg' | 'lb'",
          "currentPetId": "string | undefined"
        }
      }
    ],
    "computedState": {
      "/summary/today": "{ foodCount: number; toiletCount: number; weightCount: number; medicineCount: number; } computed from today's records for current pet",
      "/records/recent": "last 20 records for current pet, newest first",
      "/records/filtered": "records filtered by petId and optional category, newest first",
      "/reminders/pendingCount": "count of reminders where done=false and dueDate <= end of today",
      "/reminders/all": "all pending reminders sorted by dueDate",
      "/health/reminders": "pending reminders for selected health pet",
      "/trends/chartData": "aggregated { labels:string[], values:number[] } for selected pet/metric/timeRange",
      "/trends/stats": "{ avg, min, max, count, unit } derived from selected chart data"
    }
  },
  "services": {
    "PetService": {
      "purpose": "CRUD for Pet entities and current-pet settings",
      "storage": "in-memory + (future) Preferences/RDB persistence",
      "methods": ["getAll", "getById", "save", "delete", "setCurrentPet", "getCurrentPet"]
    },
    "RecordService": {
      "purpose": "CRUD for daily records and filtering",
      "storage": "in-memory + (future) Preferences/RDB persistence",
      "methods": ["getAll", "getByPet", "getRecentByPet", "save", "delete", "queryFiltered"]
    },
    "HealthService": {
      "purpose": "CRUD for vaccines, deworming, medical records, and pet selection",
      "storage": "in-memory + (future) Preferences/RDB persistence",
      "methods": ["getVaccinesByPet", "getDewormsByPet", "getMedicalRecordsByPet", "saveVaccine", "deleteVaccine", "saveMedicalRecord", "deleteMedicalRecord"]
    },
    "ReminderService": {
      "purpose": "Generate reminders from vaccines/deworms/medicine and mark done",
      "storage": "derived from HealthService + RecordService; explicit done flags in-memory",
      "methods": ["getPending", "getPendingForPet", "markDone", "refresh"]
    },
    "FamilyService": {
      "purpose": "Local family member list, invite code generation, self profile",
      "storage": "in-memory + (future) Preferences persistence",
      "methods": ["getSelf", "getMembers", "addMember", "generateInviteCode"]
    },
    "SettingsService": {
      "purpose": "Read/write app settings (weight unit)",
      "storage": "Preferences",
      "methods": ["getSettings", "setWeightUnit"]
    }
  },
  "stateMachine": {
    "surface": "home | records | trends | health | profile | pet-editor | record-editor | vaccine-editor | medical-record-editor | medical-record-detail | member-invite | reminder-list",
    "tabState": "tab-home | tab-records | tab-trends | tab-health | tab-profile",
    "lastTabBeforePush": "TabId (used by navigate-back)",
    "currentPetId": "string | undefined",
    "formState": {
      "pet": "Partial<Pet> + isNew flag",
      "record": "Partial<Record> + isNew flag",
      "vaccine": "Partial<VaccineDeworm> + isNew flag",
      "medical": "Partial<MedicalRecord> + isNew flag",
      "invite": "Partial<FamilyMember>"
    },
    "filterState": {
      "records": { "petId": "string | 'all'", "category": "RecordCategory | 'all'" },
      "trends": { "petId": "string", "metric": "'weight' | 'food' | 'toilet' | 'medicine'", "timeRange": "'week' | 'month' | 'year'" },
      "health": { "petId": "string" }
    },
    "transitions": [
      { "event": "go-to-tab", "from": "any tab surface", "to": "target tab surface", "action": "update activeTab and surface" },
      { "event": "open-pet-editor", "from": "profile", "to": "pet-editor", "action": "load pet form (new or edit)" },
      { "event": "open-record-editor", "from": "home | records", "to": "record-editor", "action": "load record form with optional category/recordId" },
      { "event": "open-vaccine-editor", "from": "health", "to": "vaccine-editor", "action": "load vaccine/deworm form" },
      { "event": "open-medical-editor", "from": "health | medical-record-detail", "to": "medical-record-editor", "action": "load medical record form" },
      { "event": "open-medical-detail", "from": "health", "to": "medical-record-detail", "action": "set selected medical record id" },
      { "event": "open-member-invite", "from": "profile", "to": "member-invite", "action": "reset invite form" },
      { "event": "open-reminder-list", "from": "home", "to": "reminder-list", "action": "n/a" },
      { "event": "navigate-back", "from": "any overlay", "to": "lastTabBeforePush", "action": "restore last tab and surface" },
      { "event": "save-*", "from": "editor overlay", "to": "lastTabBeforePush", "action": "validate, persist, refresh computed state" },
      { "event": "delete-*", "from": "editor overlay", "to": "lastTabBeforePush", "action": "confirm, delete, refresh computed state" },
      { "event": "change-current-pet", "from": "home", "to": "home", "action": "update currentPetId and all computed state" }
    ]
  },
  "interactionFlows": [
    {
      "name": "create-pet",
      "trigger": "profile-add-pet",
      "steps": [
        "open-pet-editor with isNew=true, empty form",
        "input fields: pet-editor-name, pet-editor-breed, pet-editor-birthday, pet-editor-gender, pet-editor-neutered, pet-editor-weight, pet-editor-chip",
        "tap pet-editor-save",
        "validate: name non-empty",
        "PetService.save creates pet, sets currentPetId if first pet",
        "navigate-back to profile"
      ],
      "error": "show validation inline: name required"
    },
    {
      "name": "add-food-record",
      "trigger": "home-quick-food",
      "steps": [
        "open-record-editor with category='food' and current pet preselected",
        "input record-editor-food-type, record-editor-food-amount, record-editor-time, record-editor-notes",
        "tap record-editor-save",
        "RecordService.save creates record",
        "navigate-back to home; /records/recent and /summary/today refresh"
      ],
      "error": "category and pet required"
    },
    {
      "name": "check-trends",
      "trigger": "tab-trends",
      "steps": [
        "set surface=trends, activeTab=tab-trends",
        "load /trends/petId default to currentPetId",
        "change-trends-metric and change-trends-time-range update computed chartData/stats",
        "trends-chart renders chart (placeholder polyline/bar when data exists, empty state otherwise)"
      ]
    },
    {
      "name": "add-vaccine",
      "trigger": "health-add-vaccine",
      "steps": [
        "open-vaccine-editor with type='vaccine' and health pet preselected",
        "input vaccine-editor-name, vaccine-editor-date, vaccine-editor-next-date, vaccine-editor-clinic",
        "tap vaccine-editor-save",
        "HealthService.saveVaccine persists; ReminderService.refresh adds/updates reminder",
        "navigate-back to health"
      ]
    },
    {
      "name": "add-medical",
      "trigger": "health-add-medical",
      "steps": [
        "open-medical-editor with health pet preselected",
        "input medical-editor-hospital, medical-editor-date, medical-editor-doctor, medical-editor-diagnosis, medical-editor-prescription, medical-editor-cost",
        "tap medical-editor-save",
        "HealthService.saveMedicalRecord persists",
        "navigate-back to health"
      ]
    },
    {
      "name": "view-medical-detail",
      "trigger": "health-medical-records item tap",
      "steps": [
        "open-medical-detail with selected medical record id",
        "display title/date/diagnosis/prescription/cost/attachments",
        "tap medical-detail-edit -> open-medical-editor"
      ]
    },
    {
      "name": "invite-family-member",
      "trigger": "profile-invite-member",
      "steps": [
        "open-member-invite",
        "input member-invite-name, member-invite-role",
        "tap member-invite-generate -> produce random 6-digit code",
        "tap member-invite-copy -> copy code to clipboard (stubbed)",
        "tap member-invite-save -> FamilyService.addMember"
      ]
    },
    {
      "name": "mark-reminder-done",
      "trigger": "reminder-mark-done",
      "steps": ["ReminderService.markDone sets done=true", "refresh /reminders/all and /reminders/pendingCount"]
    }
  ],
  "testTargets": {
    "tabs": ["tab-home", "tab-records", "tab-trends", "tab-health", "tab-profile"],
    "criticalFlows": [
      { "name": "create-pet", "steps": ["profile-add-pet", "pet-editor-name", "pet-editor-save"] },
      { "name": "add-food-record", "steps": ["home-quick-food", "record-editor-food-type", "record-editor-food-amount", "record-editor-save"] },
      { "name": "check-trends", "steps": ["tab-trends", "trends-metric-selector", "trends-time-range", "trends-chart"] },
      { "name": "add-vaccine", "steps": ["tab-health", "health-add-vaccine", "vaccine-editor-name", "vaccine-editor-date", "vaccine-editor-save"] },
      { "name": "add-medical", "steps": ["tab-health", "health-add-medical", "medical-editor-hospital", "medical-editor-date", "medical-editor-save"] }
    ],
    "assertions": [
      "home-current-pet-name",
      "home-reminder-count",
      "home-today-summary",
      "trends-chart-empty",
      "trends-stat-cards",
      "records-empty",
      "profile-pet-empty",
      "medical-detail-title"
    ]
  },
  "changeRequests": [
    "ui-tree.json does not define a pet-switcher target id distinct from home-pet-switcher on other surfaces; implement as local selector overlay shared across pages.",
    "ui-tree.json does not include explicit save/validation errors; implement inline validation inside editor pages and disable save until valid.",
    "ui-tree reminder-list lacks an explicit 'add reminder' action; reminders are generated automatically from vaccines/deworms and medicine records. Mark-done is the primary interaction.",
    "Pick-avatar and pick-attachments are placeholders (spec non-goals); show placeholder UI and no-op handlers."
  ]
}
