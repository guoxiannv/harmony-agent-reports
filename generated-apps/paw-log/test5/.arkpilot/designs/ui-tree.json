{
  "version": "arkpilot-uitree/v2",
  "kind": "semantic-ui-protocol",
  "appName": "宠迹·PawLog",
  "targetDevice": {
    "widthVp": 1272,
    "heightVp": 2756,
    "contentMaxWidthVp": 420
  },
  "surfaces": [
    {
      "id": "home-page",
      "surfaceId": "home",
      "pageId": "home-page",
      "name": "首页",
      "route": "pages/HomePage",
      "tabId": "tab-home",
      "semanticTargets": [
        { "id": "home-pet-switcher", "role": "action", "event": "open-pet-switcher" },
        { "id": "home-current-pet-name", "role": "assertion", "binding": "/currentPet/name" },
        { "id": "home-current-pet-avatar", "role": "assertion", "binding": "/currentPet/avatar" },
        { "id": "home-add-reminder-banner", "role": "action", "event": "open-reminder-list" },
        { "id": "home-reminder-count", "role": "assertion", "binding": "/reminders/pendingCount" },
        { "id": "home-quick-food", "role": "action", "event": "open-record-editor", "eventContext": { "category": "food" } },
        { "id": "home-quick-toilet", "role": "action", "event": "open-record-editor", "eventContext": { "category": "toilet" } },
        { "id": "home-quick-weight", "role": "action", "event": "open-record-editor", "eventContext": { "category": "weight" } },
        { "id": "home-quick-medicine", "role": "action", "event": "open-record-editor", "eventContext": { "category": "medicine" } },
        { "id": "home-recent-records-list", "role": "list", "binding": "/records/recent", "itemIdPattern": "home-recent-record-{id}", "emptyStateId": "home-recent-empty" },
        { "id": "home-today-summary", "role": "assertion", "binding": "/summary/today" },
        { "id": "home-go-health", "role": "action", "event": "go-to-health" },
        { "id": "home-go-trends", "role": "action", "event": "go-to-trends" }
      ]
    },
    {
      "id": "records-page",
      "surfaceId": "records",
      "pageId": "records-page",
      "name": "记录",
      "route": "pages/RecordsPage",
      "tabId": "tab-records",
      "semanticTargets": [
        { "id": "records-filter-pet", "role": "input", "binding": "/filter/petId", "event": "change-filter-pet" },
        { "id": "records-filter-category", "role": "input", "binding": "/filter/category", "event": "change-filter-category" },
        { "id": "records-add-button", "role": "action", "event": "open-record-editor" },
        { "id": "records-list", "role": "list", "binding": "/records/filtered", "itemIdPattern": "records-item-{id}", "emptyStateId": "records-empty" },
        { "id": "records-item-menu", "role": "action", "event": "open-record-menu", "eventContext": { "actions": ["edit", "delete"] } }
      ]
    },
    {
      "id": "trends-page",
      "surfaceId": "trends",
      "pageId": "trends-page",
      "name": "趋势",
      "route": "pages/TrendsPage",
      "tabId": "tab-trends",
      "semanticTargets": [
        { "id": "trends-pet-switcher", "role": "input", "binding": "/trends/petId", "event": "change-trends-pet" },
        { "id": "trends-metric-selector", "role": "input", "binding": "/trends/metric", "event": "change-trends-metric" },
        { "id": "trends-time-range", "role": "input", "binding": "/trends/timeRange", "event": "change-trends-time-range" },
        { "id": "trends-chart", "role": "assertion", "binding": "/trends/chartData" },
        { "id": "trends-chart-empty", "role": "assertion", "binding": "/trends/hasData" },
        { "id": "trends-stat-cards", "role": "assertion", "binding": "/trends/stats" }
      ]
    },
    {
      "id": "health-page",
      "surfaceId": "health",
      "pageId": "health-page",
      "name": "健康",
      "route": "pages/HealthPage",
      "tabId": "tab-health",
      "semanticTargets": [
        { "id": "health-pet-switcher", "role": "input", "binding": "/health/petId", "event": "change-health-pet" },
        { "id": "health-reminder-list", "role": "list", "binding": "/health/reminders", "itemIdPattern": "health-reminder-{id}", "emptyStateId": "health-reminder-empty" },
        { "id": "health-add-vaccine", "role": "action", "event": "open-vaccine-editor", "eventContext": { "type": "vaccine" } },
        { "id": "health-add-deworm", "role": "action", "event": "open-vaccine-editor", "eventContext": { "type": "deworm" } },
        { "id": "health-vaccine-history", "role": "list", "binding": "/health/vaccines", "itemIdPattern": "health-vaccine-{id}" },
        { "id": "health-deworm-history", "role": "list", "binding": "/health/deworms", "itemIdPattern": "health-deworm-{id}" },
        { "id": "health-medical-records", "role": "list", "binding": "/health/medicalRecords", "itemIdPattern": "health-medical-{id}", "emptyStateId": "health-medical-empty" },
        { "id": "health-add-medical", "role": "action", "event": "open-medical-editor" }
      ]
    },
    {
      "id": "profile-page",
      "surfaceId": "profile",
      "pageId": "profile-page",
      "name": "我的",
      "route": "pages/ProfilePage",
      "tabId": "tab-profile",
      "semanticTargets": [
        { "id": "profile-user-avatar", "role": "assertion" },
        { "id": "profile-user-name", "role": "assertion", "binding": "/family/self/name" },
        { "id": "profile-pet-list", "role": "list", "binding": "/pets", "itemIdPattern": "profile-pet-{id}", "emptyStateId": "profile-pet-empty" },
        { "id": "profile-add-pet", "role": "action", "event": "open-pet-editor" },
        { "id": "profile-family-members", "role": "list", "binding": "/family/members", "itemIdPattern": "profile-member-{id}" },
        { "id": "profile-invite-member", "role": "action", "event": "open-member-invite" },
        { "id": "profile-settings-unit", "role": "input", "binding": "/settings/weightUnit", "event": "change-weight-unit" },
        { "id": "profile-settings-about", "role": "action", "event": "open-about" }
      ]
    },
    {
      "id": "pet-editor-page",
      "surfaceId": "pet-editor",
      "pageId": "pet-editor-page",
      "name": "宠物档案编辑",
      "semanticTargets": [
        { "id": "pet-editor-avatar", "role": "action", "event": "pick-avatar" },
        { "id": "pet-editor-name", "role": "input", "binding": "/pet/name" },
        { "id": "pet-editor-breed", "role": "input", "binding": "/pet/breed" },
        { "id": "pet-editor-birthday", "role": "input", "binding": "/pet/birthday" },
        { "id": "pet-editor-gender", "role": "input", "binding": "/pet/gender" },
        { "id": "pet-editor-neutered", "role": "input", "binding": "/pet/neutered" },
        { "id": "pet-editor-weight", "role": "input", "binding": "/pet/baseWeight" },
        { "id": "pet-editor-chip", "role": "input", "binding": "/pet/chipId" },
        { "id": "pet-editor-save", "role": "action", "event": "save-pet" },
        { "id": "pet-editor-delete", "role": "action", "event": "delete-pet" },
        { "id": "pet-editor-back", "role": "action", "event": "navigate-back" }
      ]
    },
    {
      "id": "record-editor-page",
      "surfaceId": "record-editor",
      "pageId": "record-editor-page",
      "name": "记录编辑",
      "semanticTargets": [
        { "id": "record-editor-category", "role": "input", "binding": "/record/category" },
        { "id": "record-editor-pet", "role": "input", "binding": "/record/petId" },
        { "id": "record-editor-time", "role": "input", "binding": "/record/time" },
        { "id": "record-editor-food-type", "role": "input", "binding": "/record/foodType" },
        { "id": "record-editor-food-amount", "role": "input", "binding": "/record/foodAmount" },
        { "id": "record-editor-toilet-type", "role": "input", "binding": "/record/toiletType" },
        { "id": "record-editor-toilet-status", "role": "input", "binding": "/record/toiletStatus" },
        { "id": "record-editor-weight-value", "role": "input", "binding": "/record/weightValue" },
        { "id": "record-editor-medicine-name", "role": "input", "binding": "/record/medicineName" },
        { "id": "record-editor-medicine-dose", "role": "input", "binding": "/record/medicineDose" },
        { "id": "record-editor-notes", "role": "input", "binding": "/record/notes" },
        { "id": "record-editor-save", "role": "action", "event": "save-record" },
        { "id": "record-editor-delete", "role": "action", "event": "delete-record" },
        { "id": "record-editor-back", "role": "action", "event": "navigate-back" }
      ]
    },
    {
      "id": "vaccine-editor-page",
      "surfaceId": "vaccine-editor",
      "pageId": "vaccine-editor-page",
      "name": "疫苗/驱虫编辑",
      "semanticTargets": [
        { "id": "vaccine-editor-type", "role": "input", "binding": "/vaccine/type" },
        { "id": "vaccine-editor-name", "role": "input", "binding": "/vaccine/name" },
        { "id": "vaccine-editor-date", "role": "input", "binding": "/vaccine/date" },
        { "id": "vaccine-editor-next-date", "role": "input", "binding": "/vaccine/nextDate" },
        { "id": "vaccine-editor-clinic", "role": "input", "binding": "/vaccine/clinic" },
        { "id": "vaccine-editor-save", "role": "action", "event": "save-vaccine" },
        { "id": "vaccine-editor-delete", "role": "action", "event": "delete-vaccine" },
        { "id": "vaccine-editor-back", "role": "action", "event": "navigate-back" }
      ]
    },
    {
      "id": "medical-record-editor-page",
      "surfaceId": "medical-record-editor",
      "pageId": "medical-record-editor-page",
      "name": "就医病历编辑",
      "semanticTargets": [
        { "id": "medical-editor-pet", "role": "input", "binding": "/medical/petId" },
        { "id": "medical-editor-date", "role": "input", "binding": "/medical/date" },
        { "id": "medical-editor-hospital", "role": "input", "binding": "/medical/hospital" },
        { "id": "medical-editor-doctor", "role": "input", "binding": "/medical/doctor" },
        { "id": "medical-editor-diagnosis", "role": "input", "binding": "/medical/diagnosis" },
        { "id": "medical-editor-prescription", "role": "input", "binding": "/medical/prescription" },
        { "id": "medical-editor-cost", "role": "input", "binding": "/medical/cost" },
        { "id": "medical-editor-attachments", "role": "action", "event": "pick-attachments" },
        { "id": "medical-editor-save", "role": "action", "event": "save-medical" },
        { "id": "medical-editor-delete", "role": "action", "event": "delete-medical" },
        { "id": "medical-editor-back", "role": "action", "event": "navigate-back" }
      ]
    },
    {
      "id": "medical-record-detail-page",
      "surfaceId": "medical-record-detail",
      "pageId": "medical-record-detail-page",
      "name": "就医病历详情",
      "semanticTargets": [
        { "id": "medical-detail-title", "role": "assertion", "binding": "/medical/hospital" },
        { "id": "medical-detail-date", "role": "assertion", "binding": "/medical/date" },
        { "id": "medical-detail-diagnosis", "role": "assertion", "binding": "/medical/diagnosis" },
        { "id": "medical-detail-prescription", "role": "assertion", "binding": "/medical/prescription" },
        { "id": "medical-detail-cost", "role": "assertion", "binding": "/medical/cost" },
        { "id": "medical-detail-attachments", "role": "list", "binding": "/medical/attachments" },
        { "id": "medical-detail-edit", "role": "action", "event": "open-medical-editor" },
        { "id": "medical-detail-back", "role": "action", "event": "navigate-back" }
      ]
    },
    {
      "id": "member-invite-page",
      "surfaceId": "member-invite",
      "pageId": "member-invite-page",
      "name": "家庭成员邀请",
      "semanticTargets": [
        { "id": "member-invite-name", "role": "input", "binding": "/invite/name" },
        { "id": "member-invite-role", "role": "input", "binding": "/invite/role" },
        { "id": "member-invite-code", "role": "assertion", "binding": "/invite/code" },
        { "id": "member-invite-generate", "role": "action", "event": "generate-invite-code" },
        { "id": "member-invite-copy", "role": "action", "event": "copy-invite-code" },
        { "id": "member-invite-save", "role": "action", "event": "save-member" },
        { "id": "member-invite-back", "role": "action", "event": "navigate-back" }
      ]
    },
    {
      "id": "reminder-list-page",
      "surfaceId": "reminder-list",
      "pageId": "reminder-list-page",
      "name": "全部提醒",
      "semanticTargets": [
        { "id": "reminder-list", "role": "list", "binding": "/reminders/all", "itemIdPattern": "reminder-item-{id}", "emptyStateId": "reminder-empty" },
        { "id": "reminder-mark-done", "role": "action", "event": "mark-reminder-done" },
        { "id": "reminder-back", "role": "action", "event": "navigate-back" }
      ]
    }
  ],
  "events": [
    { "name": "open-pet-switcher", "description": "打开当前宠物切换浮层/选择器" },
    { "name": "open-reminder-list", "description": "进入全部提醒列表" },
    { "name": "open-record-editor", "description": "打开记录编辑页；context 可携带 category/petId/recordId" },
    { "name": "open-pet-editor", "description": "打开宠物档案编辑页；context 可携带 petId" },
    { "name": "open-vaccine-editor", "description": "打开疫苗/驱虫编辑页；context 可携带 type/id" },
    { "name": "open-medical-editor", "description": "打开就医病历编辑页；context 可携带 medicalRecordId" },
    { "name": "open-medical-detail", "description": "打开就医病历详情页" },
    { "name": "open-member-invite", "description": "打开家庭成员邀请页" },
    { "name": "go-to-health", "description": "从首页跳转到健康 Tab" },
    { "name": "go-to-trends", "description": "从首页跳转到趋势 Tab" },
    { "name": "change-filter-pet", "description": "记录页筛选宠物" },
    { "name": "change-filter-category", "description": "记录页筛选记录类别" },
    { "name": "change-trends-pet", "description": "趋势页切换宠物" },
    { "name": "change-trends-metric", "description": "趋势页切换指标" },
    { "name": "change-trends-time-range", "description": "趋势页切换时间范围" },
    { "name": "change-health-pet", "description": "健康页切换宠物" },
    { "name": "change-weight-unit", "description": "切换体重单位 kg/lb" },
    { "name": "save-pet", "description": "保存宠物档案" },
    { "name": "delete-pet", "description": "删除宠物档案" },
    { "name": "save-record", "description": "保存记录" },
    { "name": "delete-record", "description": "删除记录" },
    { "name": "save-vaccine", "description": "保存疫苗/驱虫记录" },
    { "name": "delete-vaccine", "description": "删除疫苗/驱虫记录" },
    { "name": "save-medical", "description": "保存就医病历" },
    { "name": "delete-medical", "description": "删除就医病历" },
    { "name": "save-member", "description": "保存家庭成员" },
    { "name": "generate-invite-code", "description": "生成邀请码" },
    { "name": "copy-invite-code", "description": "复制邀请码" },
    { "name": "mark-reminder-done", "description": "标记提醒为已完成" },
    { "name": "navigate-back", "description": "返回上一页/Tab" },
    { "name": "open-record-menu", "description": "打开记录项操作菜单" },
    { "name": "pick-avatar", "description": "选择宠物头像（占位）" },
    { "name": "pick-attachments", "description": "选择病历附件（占位）" },
    { "name": "open-about", "description": "打开关于页面（占位）" }
  ],
  "bindings": {
    "/currentPet": "当前选中的宠物对象",
    "/summary/today": "今日记录概览计数",
    "/reminders/pendingCount": "待处理提醒数量",
    "/reminders/all": "全部提醒列表",
    "/records/recent": "最近记录列表",
    "/records/filtered": "记录页筛选后列表",
    "/filter/petId": "记录页筛选宠物 ID",
    "/filter/category": "记录页筛选类别",
    "/trends/petId": "趋势页当前宠物 ID",
    "/trends/metric": "趋势页当前指标",
    "/trends/timeRange": "趋势页时间范围",
    "/trends/chartData": "趋势图表数据",
    "/trends/stats": "趋势统计卡片数据",
    "/health/petId": "健康页当前宠物 ID",
    "/health/reminders": "健康页提醒列表",
    "/health/vaccines": "疫苗历史列表",
    "/health/deworms": "驱虫历史列表",
    "/health/medicalRecords": "就医病历列表",
    "/pets": "全部宠物列表",
    "/family/self": "当前用户",
    "/family/members": "家庭成员列表",
    "/settings/weightUnit": "体重单位 kg/lb",
    "/pet/*": "宠物编辑表单字段",
    "/record/*": "记录编辑表单字段",
    "/vaccine/*": "疫苗/驱虫编辑表单字段",
    "/medical/*": "就医病历编辑/详情字段",
    "/invite/*": "家庭成员邀请字段"
  },
  "testTargets": {
    "tabs": ["tab-home", "tab-records", "tab-trends", "tab-health", "tab-profile"],
    "criticalFlows": [
      { "name": "create-pet", "steps": ["profile-add-pet", "pet-editor-name", "pet-editor-save"] },
      { "name": "add-food-record", "steps": ["home-quick-food", "record-editor-food-type", "record-editor-food-amount", "record-editor-save"] },
      { "name": "check-trends", "steps": ["tab-trends", "trends-metric-selector", "trends-time-range", "trends-chart"] },
      { "name": "add-vaccine", "steps": ["tab-health", "health-add-vaccine", "vaccine-editor-name", "vaccine-editor-date", "vaccine-editor-save"] },
      { "name": "add-medical", "steps": ["tab-health", "health-add-medical", "medical-editor-hospital", "medical-editor-date", "medical-editor-save"] }
    ]
  }
}
