{
  "uiTreePath": ".arkpilot/designs/ui-tree.json",
  "appName": "宠迹 · PawLog",
  "dataModel": {
    "entities": {
      "Pet": {
        "id": "string (uuid)",
        "name": "string (required)",
        "avatar": "string | undefined",
        "breed": "string",
        "birthday": "string (ISO date)",
        "gender": "'male' | 'female' | 'unknown'",
        "currentWeight": "number | undefined (kg)",
        "createdAt": "number (timestamp ms)",
        "updatedAt": "number (timestamp ms)"
      },
      "Record": {
        "id": "string (uuid)",
        "petId": "string",
        "type": "'food' | 'waste' | 'weight' | 'medicine'",
        "value": "string | number | undefined",
        "unit": "string | undefined",
        "datetime": "number (timestamp ms)",
        "note": "string",
        "createdAt": "number (timestamp ms)"
      },
      "Reminder": {
        "id": "string (uuid)",
        "petId": "string",
        "type": "'vaccine' | 'deworm'",
        "name": "string",
        "date": "string (ISO date)",
        "repeat": "'none' | 'weekly' | 'monthly' | 'yearly'",
        "enabled": "boolean",
        "createdAt": "number (timestamp ms)"
      },
      "MedicalRecord": {
        "id": "string (uuid)",
        "petId": "string",
        "date": "string (ISO date)",
        "hospital": "string",
        "diagnosis": "string",
        "prescription": "string",
        "attachments": "string[] (local paths)",
        "createdAt": "number (timestamp ms)"
      },
      "FamilyMember": {
        "id": "string (uuid)",
        "name": "string",
        "avatar": "string | undefined",
        "role": "'owner' | 'member'",
        "joinedAt": "number (timestamp ms)"
      },
      "FamilySettings": {
        "shareEnabled": "boolean",
        "inviteCode": "string | undefined"
      }
    },
    "settingsAndFormState": {
      "currentPetId": "string | undefined",
      "home": {
        "selectedPetId": "string | undefined",
        "todaySummary": "TodaySummary",
        "upcomingReminders": "ReminderWithPet[]",
        "recentRecords": "RecordWithPet[]"
      },
      "records": {
        "filterPetId": "'all' | string",
        "filterType": "'all' | RecordType"
      },
      "trends": {
        "selectedPetId": "string",
        "metric": "'weight' | 'food' | 'waste' | 'medicine'",
        "periodDays": "7 | 30 | 90"
      },
      "family": {
        "shareEnabled": "boolean"
      },
      "forms": {
        "addRecord": "AddRecordForm",
        "addPet": "AddPetForm",
        "addReminder": "AddReminderForm",
        "addMedical": "AddMedicalForm"
      }
    },
    "computedState": {
      "todaySummary": "aggregated counts for food/waste/medicine and latest weight for selected/current pet",
      "upcomingReminders": "reminders whose date <= today + 7, sorted by date asc",
      "recentRecords": "last 20 records for current pet or all pets, sorted by datetime desc",
      "filteredRecords": "records filtered by petId and type",
      "trendPoints": "daily aggregated points for selected metric and period",
      "petAge": "computed from birthday to today"
    }
  },
  "services": {
    "PetStore": {
      "role": "local persistence for pets",
      "methods": ["listPets", "getPet", "savePet", "deletePet"]
    },
    "RecordStore": {
      "role": "local persistence for records",
      "methods": ["listRecords", "listRecordsByPet", "saveRecord", "deleteRecord"]
    },
    "ReminderStore": {
      "role": "local persistence for reminders",
      "methods": ["listReminders", "listRemindersByPet", "saveReminder", "deleteReminder"]
    },
    "MedicalStore": {
      "role": "local persistence for medical records",
      "methods": ["listMedical", "listMedicalByPet", "saveMedical", "deleteMedical"]
    },
    "FamilyStore": {
      "role": "local persistence for family members and settings",
      "methods": ["listMembers", "addMember", "removeMember", "getSettings", "setShareEnabled"]
    },
    "SummaryService": {
      "role": "aggregate today's counts and latest weight",
      "methods": ["getTodaySummary", "getUpcomingReminders", "getRecentRecords"]
    },
    "TrendsService": {
      "role": "aggregate trend points from records",
      "methods": ["getTrendPoints"]
    }
  },
  "stateMachine": {
    "shell": {
      "initial": "home",
      "tabSurfaces": ["home", "pets", "records", "trends", "health", "family"],
      "nonTabSurfaces": ["pet-detail", "add-record", "add-pet", "add-reminder", "add-medical"],
      "transitions": {
        "goToTab": "switch tab surface and activeTab",
        "openAddRecord": "push add-record surface",
        "openPetDetail": "push pet-detail surface with petId",
        "openAddPet": "push add-pet surface",
        "openEditPet": "push add-pet surface with petId",
        "openAddReminder": "push add-reminder surface",
        "openAddMedical": "push add-medical surface",
        "navigateBack": "return to previous tab surface"
      }
    },
    "recordForm": {
      "states": ["editing", "saving", "success", "error"],
      "transitions": {
        "selectPet": "set petId",
        "selectType": "set record type",
        "inputValue": "set value/unit",
        "inputDatetime": "set datetime",
        "inputNote": "set note",
        "save": "validate then persist and return",
        "cancel": "discard and return"
      }
    },
    "petForm": {
      "states": ["editing", "saving", "success", "error"],
      "transitions": {
        "inputName": "set name",
        "inputBreed": "set breed",
        "inputBirthday": "set birthday",
        "selectGender": "set gender",
        "inputWeight": "set currentWeight",
        "selectAvatar": "set avatar",
        "save": "validate then persist and return",
        "cancel": "discard and return"
      }
    },
    "reminderForm": {
      "states": ["editing", "saving", "success", "error"],
      "transitions": {
        "selectPet": "set petId",
        "selectType": "set reminder type",
        "inputName": "set name",
        "inputDate": "set date",
        "selectRepeat": "set repeat",
        "save": "validate then persist and return",
        "cancel": "discard and return"
      }
    },
    "medicalForm": {
      "states": ["editing", "saving", "success", "error"],
      "transitions": {
        "selectPet": "set petId",
        "inputDate": "set date",
        "inputHospital": "set hospital",
        "inputDiagnosis": "set diagnosis",
        "inputPrescription": "set prescription",
        "addAttachment": "append attachment path",
        "save": "validate then persist and return",
        "cancel": "discard and return"
      }
    }
  },
  "interactionFlows": [
    {
      "name": "first-launch empty state",
      "trigger": "app starts with zero pets",
      "steps": [
        "home-page shows empty state",
        "user taps home-empty-add-pet or home-add-pet-button",
        "navigate to add-pet-page",
        "user fills add-pet-name (required), add-pet-breed, add-pet-birthday, add-pet-gender, add-pet-weight",
        "user taps add-pet-save",
        "save pet to PetStore, set as current pet, return to home-page"
      ],
      "sideEffects": ["PetStore.savePet", "AppStorage.currentPetId updated"],
      "errorPaths": ["name empty -> inline validation, stay on form"]
    },
    {
      "name": "quick record from home",
      "trigger": "user taps home-quick-record-* or home-floating-record-button",
      "steps": [
        "open add-record-page with current pet preselected",
        "user selects pet, type, value, datetime, note",
        "user taps add-record-save",
        "persist record, return, refresh home summary and recent records"
      ],
      "sideEffects": ["RecordStore.saveRecord", "home summary recomputed"]
    },
    {
      "name": "view pet detail",
      "trigger": "user taps pets-item-{id}",
      "steps": [
        "navigate to pet-detail-page with petId",
        "display pet info and recent records",
        "user can tap pet-detail-edit or pet-detail-delete"
      ],
      "sideEffects": ["PetStore.getPet", "RecordStore.listRecordsByPet"],
      "errorPaths": ["delete requires confirmation"]
    },
    {
      "name": "records filtering",
      "trigger": "user changes records-filter-pet or records-filter-type",
      "steps": ["update filter state", "recompute filteredRecords"],
      "sideEffects": ["records view state updated"]
    },
    {
      "name": "trends period/metric selection",
      "trigger": "user selects pet, metric, or period",
      "steps": ["update trends state", "TrendsService.getTrendPoints", "update chart and summary"]
    },
    {
      "name": "health reminders",
      "trigger": "user visits health-page",
      "steps": ["load reminders and medical records", "display status chips"],
      "sideEffects": ["ReminderStore.listReminders", "MedicalStore.listMedical"]
    },
    {
      "name": "family sharing",
      "trigger": "user visits family-page",
      "steps": ["load members and settings", "toggle share, generate invite code, add mock member"],
      "sideEffects": ["FamilyStore.setShareEnabled", "FamilyStore.addMember"]
    }
  ],
  "testTargets": {
    "home-page": [
      "home-pet-switcher",
      "home-add-pet-button",
      "home-quick-record-food",
      "home-quick-record-waste",
      "home-quick-record-weight",
      "home-quick-record-medicine",
      "home-today-food-count",
      "home-today-waste-count",
      "home-latest-weight",
      "home-today-medicine-count",
      "home-reminder-list",
      "home-recent-record-list",
      "home-floating-record-button",
      "home-empty-add-pet"
    ],
    "pets-page": ["pets-add-button", "pets-list"],
    "pet-detail-page": [
      "pet-detail-back",
      "pet-detail-edit",
      "pet-detail-delete",
      "pet-detail-name",
      "pet-detail-avatar",
      "pet-detail-info-breed",
      "pet-detail-info-age",
      "pet-detail-info-weight",
      "pet-detail-add-record",
      "pet-detail-record-list"
    ],
    "records-page": ["records-filter-pet", "records-filter-type", "records-list", "records-add-button"],
    "trends-page": [
      "trends-pet-selector",
      "trends-metric-selector",
      "trends-period-7d",
      "trends-period-30d",
      "trends-period-90d",
      "trends-chart",
      "trends-summary-value"
    ],
    "health-page": [
      "health-add-reminder",
      "health-add-medical",
      "health-reminder-list",
      "health-medical-list"
    ],
    "family-page": [
      "family-invite-button",
      "family-share-toggle",
      "family-member-list"
    ],
    "add-record-page": [
      "add-record-back",
      "add-record-pet-picker",
      "add-record-type-food",
      "add-record-type-waste",
      "add-record-type-weight",
      "add-record-type-medicine",
      "add-record-value",
      "add-record-datetime",
      "add-record-note",
      "add-record-save",
      "add-record-cancel"
    ],
    "add-pet-page": [
      "add-pet-back",
      "add-pet-avatar",
      "add-pet-name",
      "add-pet-breed",
      "add-pet-birthday",
      "add-pet-gender",
      "add-pet-weight",
      "add-pet-save",
      "add-pet-cancel"
    ],
    "add-reminder-page": [
      "add-reminder-back",
      "add-reminder-pet-picker",
      "add-reminder-type-vaccine",
      "add-reminder-type-deworm",
      "add-reminder-name",
      "add-reminder-date",
      "add-reminder-repeat",
      "add-reminder-save",
      "add-reminder-cancel"
    ],
    "add-medical-page": [
      "add-medical-back",
      "add-medical-pet-picker",
      "add-medical-date",
      "add-medical-hospital",
      "add-medical-diagnosis",
      "add-medical-prescription",
      "add-medical-attachment",
      "add-medical-save",
      "add-medical-cancel"
    ]
  },
  "changeRequests": []
}
