{
  "uiTreePath": ".arkpilot/designs/ui-tree.json",
  "appName": "宠迹 · PawLog",
  "dataModel": {
    "entities": [
      {
        "name": "Pet",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "name", "type": "string", "required": true },
          { "name": "species", "type": "'dog' | 'cat' | 'other'", "required": true },
          { "name": "breed", "type": "string", "required": false },
          { "name": "gender", "type": "'male' | 'female' | 'unknown'", "required": false },
          { "name": "birthDate", "type": "number", "required": true },
          { "name": "avatarUrl", "type": "string", "required": false },
          { "name": "weightKg", "type": "number", "required": false },
          { "name": "neutered", "type": "boolean", "required": false },
          { "name": "microchipId", "type": "string", "required": false },
          { "name": "allergens", "type": "string[]", "required": false },
          { "name": "tags", "type": "string[]", "required": false },
          { "name": "notes", "type": "string", "required": false }
        ]
      },
      {
        "name": "Record",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "petId", "type": "string", "required": true },
          { "name": "type", "type": "'food' | 'toilet' | 'weight' | 'medicine'", "required": true },
          { "name": "createdAt", "type": "number", "required": true },
          { "name": "recordedAt", "type": "number", "required": true },
          { "name": "createdBy", "type": "string", "required": true },
          { "name": "foodName", "type": "string", "required": false },
          { "name": "amount", "type": "number", "required": false },
          { "name": "unit", "type": "string", "required": false },
          { "name": "toiletType", "type": "'pee' | 'poo' | 'vomit' | 'other'", "required": false },
          { "name": "condition", "type": "string", "required": false },
          { "name": "medicineName", "type": "string", "required": false },
          { "name": "dose", "type": "string", "required": false },
          { "name": "taken", "type": "boolean", "required": false },
          { "name": "notes", "type": "string", "required": false }
        ]
      },
      {
        "name": "Reminder",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "petId", "type": "string", "required": true },
          { "name": "title", "type": "string", "required": true },
          { "name": "type", "type": "'vaccine' | 'deworm' | 'other'", "required": true },
          { "name": "dueDate", "type": "number", "required": true },
          { "name": "repeatDays", "type": "number", "required": false },
          { "name": "completed", "type": "boolean", "required": true },
          { "name": "notified", "type": "boolean", "required": true }
        ]
      },
      {
        "name": "MedicalRecord",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "petId", "type": "string", "required": true },
          { "name": "visitDate", "type": "number", "required": true },
          { "name": "clinic", "type": "string", "required": false },
          { "name": "doctor", "type": "string", "required": false },
          { "name": "complaint", "type": "string", "required": false },
          { "name": "diagnosis", "type": "string", "required": false },
          { "name": "treatment", "type": "string", "required": false },
          { "name": "medicine", "type": "string", "required": false },
          { "name": "cost", "type": "number", "required": false },
          { "name": "notes", "type": "string", "required": false },
          { "name": "photos", "type": "string[]", "required": false }
        ]
      },
      {
        "name": "FamilyMember",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "displayName", "type": "string", "required": true },
          { "name": "avatarUrl", "type": "string", "required": false },
          { "name": "role", "type": "'admin' | 'member'", "required": true }
        ]
      },
      {
        "name": "User",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "displayName", "type": "string", "required": true },
          { "name": "avatarUrl", "type": "string", "required": false },
          { "name": "role", "type": "'admin' | 'member'", "required": true }
        ]
      }
    ],
    "settingsAndFormState": [
      { "name": "selectedPetId", "type": "string | null" },
      { "name": "recordFilters", "type": "{ petId?: string; type?: Record['type']; keyword?: string; date?: number }" },
      { "name": "chartPeriod", "type": "7 | 30 | 90" },
      { "name": "chartMetric", "type": "'weight' | 'water' | 'toilet'" },
      { "name": "currentSurface", "type": "string" },
      { "name": "activeTab", "type": "TabId" },
      { "name": "deleteTarget", "type": "{ kind: string; id: string } | null" }
    ],
    "computedState": [
      { "name": "selectedPet", "type": "Pet | null", "from": "/pets/all + selectedPetId" },
      { "name": "todayReminders", "type": "Reminder[]", "from": "/reminders/byPet filtered by dueDate" },
      { "name": "filteredRecords", "type": "Record[]", "from": "/records/all + recordFilters" },
      { "name": "recentRecords", "type": "Record[]", "from": "/records/all sorted desc limited 20" },
      { "name": "chartDataPoints", "type": "{ date: string; value: number }[]", "from": "/records/byPet + chartPeriod + chartMetric" }
    ],
    "persistence": {
      "strategy": "local-first, AppStorage + Preferences for durable persistence",
      "keys": ["pawlog_pets", "pawlog_records", "pawlog_reminders", "pawlog_medical", "pawlog_family", "pawlog_user"],
      "cloudSync": "deferred: family sharing uses local space with invite code; cloud sync stubbed"
    }
  },
  "services": [
    {
      "name": "Store",
      "responsibility": "Local key-value persistence via @ohos.data.preferences. Read/write JSON blobs for each entity type.",
      "methods": ["get<T>(key)", "set<T>(key, value)", "clear()"]
    },
    {
      "name": "Repository",
      "responsibility": "CRUD and query logic for pets, records, reminders, medical records, family members, and computed aggregations.",
      "methods": [
        "listPets()", "getPet(id)", "savePet(pet)", "deletePet(id)",
        "listRecords(filter)", "getRecord(id)", "saveRecord(record)", "deleteRecord(id)",
        "listReminders(petId?)", "getReminder(id)", "saveReminder(reminder)", "deleteReminder(id)",
        "listMedicalRecords(petId?)", "getMedicalRecord(id)", "saveMedicalRecord(mr)", "deleteMedicalRecord(id)",
        "listMembers()", "addMember(member)", "removeMember(id)",
        "getCurrentUser()", "setCurrentUser(user)"
      ]
    },
    {
      "name": "NotificationService",
      "responsibility": "Schedule local reminders for vaccines/deworm; emit today/upcoming lists. Stubbed if no notification permission.",
      "methods": ["schedule(reminder)", "cancel(id)", "getTodayAndUpcoming(petId?)"]
    },
    {
      "name": "FamilyService",
      "responsibility": "Generate invite codes, accept invites, manage shared space and roles. Cloud sync deferred; local-only implementation.",
      "methods": ["generateInviteCode()", "joinByCode(code)", "listSharedPets()"]
    },
    {
      "name": "PhotoService",
      "responsibility": "Pick photos from album/camera and copy to app private directory. Stubbed with placeholder paths if unavailable.",
      "methods": ["pickAndSave()"]
    }
  ],
  "stateMachine": {
    "rootState": {
      "surface": "home | records | health | family | profile | pet-editor | record-editor | record-detail | chart-detail | reminder-editor | medical-record-editor | medical-record-detail | member-invite",
      "activeTab": "tab-home | tab-records | tab-health | tab-family | tab-profile",
      "selectedPetId": "string | null",
      "sheet": "none | pet-picker | record-type-picker",
      "dialog": "none | confirm-delete"
    },
    "transitions": [
      { "event": "go-to-tab", "from": "*", "to": "tab surface", "effect": "set activeTab and surface" },
      { "event": "open-pet-editor", "from": "*", "to": "pet-editor surface", "effect": "set editingPetId optional" },
      { "event": "save-pet", "from": "pet-editor", "to": "previous surface", "effect": "persist pet, select if first" },
      { "event": "delete-pet", "from": "pet-editor", "to": "previous surface", "effect": "confirm then delete cascade" },
      { "event": "open-record-type-sheet", "from": "home", "to": "record-type-picker sheet", "effect": "record surface" },
      { "event": "select-food|toilet|weight|medicine", "from": "record-type-picker", "to": "record-editor", "effect": "set record type and pet" },
      { "event": "open-record-editor", "from": "*", "to": "record-editor", "effect": "set editingRecordId and type" },
      { "event": "save-record", "from": "record-editor", "to": "previous surface", "effect": "persist record" },
      { "event": "delete-record", "from": "record-detail|record-editor", "to": "previous surface", "effect": "confirm then delete" },
      { "event": "open-chart-detail", "from": "health", "to": "chart-detail", "effect": "set chartMetric" },
      { "event": "set-chart-period", "from": "health|chart-detail", "to": "same surface", "effect": "set chartPeriod and recompute" },
      { "event": "open-reminder-editor", "from": "health", "to": "reminder-editor", "effect": "set editingReminderId" },
      { "event": "save-reminder", "from": "reminder-editor", "to": "health", "effect": "persist reminder, schedule notification" },
      { "event": "delete-reminder", "from": "reminder-editor", "to": "health", "effect": "confirm then delete" },
      { "event": "open-medical-record-editor", "from": "health", "to": "medical-record-editor", "effect": "set editingMedicalRecordId" },
      { "event": "save-medical-record", "from": "medical-record-editor", "to": "health", "effect": "persist medical record" },
      { "event": "delete-medical-record", "from": "medical-record-detail|medical-record-editor", "to": "health", "effect": "confirm then delete" },
      { "event": "open-member-invite", "from": "family", "to": "member-invite", "effect": "generate invite code" },
      { "event": "confirm-delete", "from": "confirm-delete dialog", "to": "previous surface", "effect": "delete deleteTarget" },
      { "event": "cancel-delete", "from": "confirm-delete dialog", "to": "previous surface", "effect": "clear deleteTarget" }
    ]
  },
  "interactionFlows": [
    {
      "name": "Add first pet",
      "trigger": "app starts with zero pets",
      "steps": [
        "home-page shows empty pet state with home-add-pet-button",
        "tap home-add-pet-button -> open-pet-editor with no id",
        "fill pet-editor-name-input, pet-editor-species-picker, pet-editor-gender-picker, pet-editor-birthdate-picker",
        "tap pet-editor-save-button -> save-pet -> persist and return",
        "selectedPetId set to new pet"
      ],
      "errorPath": "Validation error shown if name, species, or birthDate missing"
    },
    {
      "name": "Quick log",
      "trigger": "tap home-quick-log-button",
      "steps": [
        "open-pet-picker-sheet if selectedPetId null",
        "tap pet-picker-item-{id} -> select pet",
        "open record-type-sheet",
        "tap record-type-food|toilet|weight|medicine",
        "open record-editor-page pre-filled with pet and type",
        "fill type-specific fields and tap record-editor-save-button",
        "save-record -> persist and return"
      ],
      "errorPath": "Required type-specific fields validated before save"
    },
    {
      "name": "View health trends",
      "trigger": "go-to-health tab",
      "steps": [
        "health-page loads selected pet and default 7-day charts",
        "tap health-period-7d/30d/90d -> set-chart-period -> recompute chartDataPoints",
        "tap health-weight-chart-card -> open-chart-detail for weight metric",
        "chart-detail-page shows data list with chart-detail-data-list"
      ]
    },
    {
      "name": "Set vaccine reminder",
      "trigger": "tap health-add-reminder-button",
      "steps": [
        "open-reminder-editor with no id",
        "select pet, type, title, date, repeat",
        "tap reminder-editor-save-button -> save-reminder -> persist and schedule notification",
        "home-page and health-page show today/upcoming reminders"
      ]
    },
    {
      "name": "Archive medical record",
      "trigger": "tap health-add-medical-record-button",
      "steps": [
        "open-medical-record-editor",
        "fill clinic, doctor, complaint, diagnosis, treatment, medicine, cost, notes",
        "tap medical-editor-photo-grid -> add-photo -> PhotoService copies image to private dir",
        "tap medical-editor-save-button -> save-medical-record -> persist",
        "health-medical-record-list updated"
      ]
    },
    {
      "name": "Invite family member",
      "trigger": "tap family-invite-button",
      "steps": [
        "open-member-invite -> FamilyService.generateInviteCode()",
        "member-invite-code-display shows code",
        "tap member-invite-copy-button or member-invite-share-button"
      ]
    },
    {
      "name": "Delete with confirmation",
      "trigger": "tap delete button",
      "steps": [
        "set deleteTarget = { kind, id }",
        "show confirm-delete-dialog",
        "tap confirm-delete-confirm-button -> confirm-delete -> delete target and return",
        "tap confirm-delete-cancel-button -> cancel-delete -> clear target and return"
      ]
    }
  ],
  "testTargets": {
    "home-page": ["home-pet-switcher", "home-current-pet-avatar", "home-current-pet-name", "home-add-pet-button", "home-quick-log-button", "home-reminder-list", "home-recent-record-list"],
    "records-page": ["records-add-button", "records-search-input", "records-pet-filter", "records-type-filter", "records-date-filter", "records-timeline-list"],
    "health-page": ["health-pet-switcher", "health-period-7d", "health-period-30d", "health-period-90d", "health-weight-chart-card", "health-water-chart-card", "health-toilet-chart-card", "health-reminder-list", "health-add-reminder-button", "health-medical-record-list", "health-add-medical-record-button"],
    "family-page": ["family-invite-button", "family-member-list", "family-shared-pet-list"],
    "profile-page": ["profile-user-avatar", "profile-user-name", "profile-manage-pets-button", "profile-export-data-button", "profile-settings-button", "profile-about-button"],
    "editor-pages": ["pet-editor-save-button", "record-editor-save-button", "reminder-editor-save-button", "medical-editor-save-button"],
    "dialogs": ["confirm-delete-confirm-button", "confirm-delete-cancel-button"]
  },
  "changeRequests": [
    {
      "id": "CR-01",
      "surface": "profile-page",
      "issue": "No pet-list page route in ui-tree; profile-manage-pets-button target undefined. Plan will route to pet-editor-page in list/select mode or reuse pet-picker-sheet.",
      "severity": "medium"
    },
    {
      "id": "CR-02",
      "surface": "record-editor-page",
      "issue": "One generic record editor covers all record types. Implement dynamic field visibility per type.",
      "severity": "low"
    },
    {
      "id": "CR-03",
      "surface": "global",
      "issue": "ui-tree does not define settings/about pages. profile-settings-button and profile-about-button will show simple sheets or toasts if not implemented.",
      "severity": "low"
    },
    {
      "id": "CR-04",
      "surface": "home-page",
      "issue": "home-notification-button event open-reminders not defined in events array; map to go-to-health tab.",
      "severity": "low"
    }
  ]
}
