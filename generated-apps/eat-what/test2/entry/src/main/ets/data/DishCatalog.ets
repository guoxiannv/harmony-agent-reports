export class DishCatalog {
  static all(): Dish[] {
    return CATALOG;
  }

  static byId(id: string): Dish | null {
    for (let i = 0; i < CATALOG.length; i++) {
      if (CATALOG[i].id === id) {
        return CATALOG[i];
      }
    }
    return null;
  }

  static size(): number {
    return CATALOG.length;
  }
}
