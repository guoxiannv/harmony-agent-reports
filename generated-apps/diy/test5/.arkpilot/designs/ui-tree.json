{
  "version": "arkpilot-uitree/v2",
  "kind": "semantic-ui-protocol",
  "appName": "手作·印记",
  "targetDevice": {
    "widthVp": 1272,
    "heightVp": 2756,
    "contentMaxWidthVp": 420
  },
  "surfaces": [
    {
      "id": "home-page",
      "surfaceId": "home",
      "pageId": "home-page",
      "name": "首页",
      "route": "pages/Home",
      "tabId": "tab-home",
      "semanticTargets": [
        {
          "id": "home-signin-button",
          "role": "action",
          "event": "member-signin"
        },
        {
          "id": "home-search-input",
          "role": "input",
          "event": "search-members"
        },
        {
          "id": "home-sleep-banner",
          "role": "assertion",
          "binding": "/sleep/reminders"
        },
        {
          "id": "home-sleep-count",
          "role": "assertion",
          "binding": "/sleep/count"
        },
        {
          "id": "home-low-stock-banner",
          "role": "assertion",
          "binding": "/inventory/lowStockItems"
        },
        {
          "id": "home-today-course-list",
          "role": "list",
          "binding": "/courses/today",
          "itemIdPattern": "home-today-course-{id}",
          "emptyStateId": "home-today-course-empty"
        },
        {
          "id": "home-quick-points",
          "role": "action",
          "event": "navigate-points"
        },
        {
          "id": "home-quick-inventory",
          "role": "action",
          "event": "navigate-inventory"
        },
        {
          "id": "home-bottom-tab-bar",
          "role": "navigation",
          "binding": "/navigation/activeTab"
        }
      ]
    },
    {
      "id": "members-page",
      "surfaceId": "members",
      "pageId": "members-page",
      "name": "会员",
      "route": "pages/Members",
      "tabId": "tab-members",
      "semanticTargets": [
        {
          "id": "members-add-button",
          "role": "action",
          "event": "open-add-member"
        },
        {
          "id": "members-search-input",
          "role": "input",
          "event": "filter-members"
        },
        {
          "id": "members-filter-chip",
          "role": "input",
          "event": "toggle-craft-filter"
        },
        {
          "id": "members-list",
          "role": "list",
          "binding": "/members",
          "itemIdPattern": "members-item-{id}",
          "emptyStateId": "members-empty-state"
        },
        {
          "id": "members-item-{id}-detail",
          "role": "action",
          "event": "navigate-member-detail"
        }
      ]
    },
    {
      "id": "member-detail-page",
      "surfaceId": "member-detail",
      "pageId": "member-detail-page",
      "name": "会员详情",
      "route": "pages/MemberDetail",
      "semanticTargets": [
        {
          "id": "member-detail-back",
          "role": "action",
          "event": "navigate-back"
        },
        {
          "id": "member-detail-edit",
          "role": "action",
          "event": "open-edit-member"
        },
        {
          "id": "member-detail-avatar",
          "role": "assertion",
          "binding": "/member/avatar"
        },
        {
          "id": "member-detail-name",
          "role": "assertion",
          "binding": "/member/name"
        },
        {
          "id": "member-detail-points",
          "role": "assertion",
          "binding": "/member/points"
        },
        {
          "id": "member-detail-tags",
          "role": "list",
          "binding": "/member/craftTags",
          "itemIdPattern": "member-detail-tag-{index}",
          "emptyStateId": "member-detail-tags-empty"
        },
        {
          "id": "member-detail-works-gallery",
          "role": "list",
          "binding": "/member/works",
          "itemIdPattern": "member-detail-work-{id}",
          "emptyStateId": "member-detail-works-empty"
        },
        {
          "id": "member-detail-add-work",
          "role": "action",
          "event": "open-add-work"
        },
        {
          "id": "member-detail-points-history",
          "role": "list",
          "binding": "/member/pointsHistory",
          "itemIdPattern": "member-detail-points-record-{id}",
          "emptyStateId": "member-detail-points-empty"
        },
        {
          "id": "member-detail-signin-button",
          "role": "action",
          "event": "member-signin"
        },
        {
          "id": "member-detail-redeem-points",
          "role": "action",
          "event": "open-redeem-points"
        }
      ]
    },
    {
      "id": "courses-page",
      "surfaceId": "courses",
      "pageId": "courses-page",
      "name": "课程",
      "route": "pages/Courses",
      "tabId": "tab-courses",
      "semanticTargets": [
        {
          "id": "courses-calendar-toggle",
          "role": "input",
          "event": "toggle-calendar-view"
        },
        {
          "id": "courses-date-picker",
          "role": "input",
          "event": "select-course-date"
        },
        {
          "id": "courses-list",
          "role": "list",
          "binding": "/courses/byDate",
          "itemIdPattern": "courses-item-{id}",
          "emptyStateId": "courses-empty-state"
        },
        {
          "id": "courses-item-{id}-book",
          "role": "action",
          "event": "navigate-course-booking"
        },
        {
          "id": "courses-add-button",
          "role": "action",
          "event": "open-add-course"
        }
      ]
    },
    {
      "id": "course-booking-page",
      "surfaceId": "course-booking",
      "pageId": "course-booking-page",
      "name": "课程预约",
      "route": "pages/CourseBooking",
      "semanticTargets": [
        {
          "id": "course-booking-back",
          "role": "action",
          "event": "navigate-back"
        },
        {
          "id": "course-booking-member-picker",
          "role": "input",
          "event": "select-member"
        },
        {
          "id": "course-booking-confirm",
          "role": "action",
          "event": "confirm-booking"
        },
        {
          "id": "course-booking-material-warning",
          "role": "assertion",
          "binding": "/course/materialShortage"
        },
        {
          "id": "course-booking-seats-left",
          "role": "assertion",
          "binding": "/course/seatsLeft"
        }
      ]
    },
    {
      "id": "inventory-page",
      "surfaceId": "inventory",
      "pageId": "inventory-page",
      "name": "库存",
      "route": "pages/Inventory",
      "tabId": "tab-inventory",
      "semanticTargets": [
        {
          "id": "inventory-add-button",
          "role": "action",
          "event": "open-add-inventory"
        },
        {
          "id": "inventory-search-input",
          "role": "input",
          "event": "filter-inventory"
        },
        {
          "id": "inventory-list",
          "role": "list",
          "binding": "/inventory",
          "itemIdPattern": "inventory-item-{id}",
          "emptyStateId": "inventory-empty-state"
        },
        {
          "id": "inventory-item-{id}-adjust",
          "role": "action",
          "event": "open-adjust-stock"
        },
        {
          "id": "inventory-low-stock-section",
          "role": "list",
          "binding": "/inventory/lowStockItems",
          "itemIdPattern": "inventory-low-item-{id}",
          "emptyStateId": "inventory-no-low-stock"
        }
      ]
    },
    {
      "id": "profile-page",
      "surfaceId": "profile",
      "pageId": "profile-page",
      "name": "我的",
      "route": "pages/Profile",
      "tabId": "tab-profile",
      "semanticTargets": [
        {
          "id": "profile-studio-name",
          "role": "input",
          "event": "update-studio-name"
        },
        {
          "id": "profile-sleep-threshold",
          "role": "input",
          "event": "update-sleep-threshold"
        },
        {
          "id": "profile-points-rule-signin",
          "role": "input",
          "event": "update-signin-points"
        },
        {
          "id": "profile-points-rule-spend",
          "role": "input",
          "event": "update-spend-points"
        },
        {
          "id": "profile-export-data",
          "role": "action",
          "event": "export-data"
        },
        {
          "id": "profile-about",
          "role": "action",
          "event": "open-about"
        }
      ]
    }
  ],
  "events": [
    { "name": "member-signin", "context": ["memberId"] },
    { "name": "search-members", "context": ["keyword"] },
    { "name": "filter-members", "context": ["craftTag"] },
    { "name": "open-add-member", "context": [] },
    { "name": "navigate-member-detail", "context": ["memberId"] },
    { "name": "open-edit-member", "context": ["memberId"] },
    { "name": "open-add-work", "context": ["memberId"] },
    { "name": "open-redeem-points", "context": ["memberId"] },
    { "name": "toggle-calendar-view", "context": [] },
    { "name": "select-course-date", "context": ["date"] },
    { "name": "open-add-course", "context": [] },
    { "name": "navigate-course-booking", "context": ["courseId"] },
    { "name": "select-member", "context": ["memberId"] },
    { "name": "confirm-booking", "context": ["courseId", "memberId"] },
    { "name": "open-add-inventory", "context": [] },
    { "name": "filter-inventory", "context": ["keyword"] },
    { "name": "open-adjust-stock", "context": ["inventoryId"] },
    { "name": "update-sleep-threshold", "context": ["days"] },
    { "name": "update-signin-points", "context": ["points"] },
    { "name": "update-spend-points", "context": ["pointsPerYuan"] },
    { "name": "export-data", "context": [] },
    { "name": "navigate-points", "context": [] },
    { "name": "navigate-inventory", "context": [] },
    { "name": "navigate-back", "context": [] }
  ],
  "bindings": {
    "/summary/todayCourses": "今日课程列表",
    "/sleep/reminders": "沉睡会员提醒摘要",
    "/sleep/count": "沉睡会员数量",
    "/inventory/lowStockItems": "低库存物品列表",
    "/members": "会员列表",
    "/member/name": "会员姓名",
    "/member/avatar": "会员头像",
    "/member/points": "会员积分余额",
    "/member/craftTags": "擅长工艺标签",
    "/member/works": "会员作品图列表",
    "/member/pointsHistory": "会员积分流水",
    "/courses/byDate": "按日期筛选的课程列表",
    "/courses/today": "今日课程列表",
    "/course/seatsLeft": "课程剩余名额",
    "/course/materialShortage": "课程耗材是否不足",
    "/inventory": "库存物品列表"
  },
  "testTargets": [
    "home-signin-button",
    "home-sleep-banner",
    "home-low-stock-banner",
    "home-today-course-list",
    "members-add-button",
    "members-list",
    "member-detail-edit",
    "member-detail-points",
    "member-detail-works-gallery",
    "member-detail-signin-button",
    "courses-calendar-toggle",
    "courses-list",
    "course-booking-member-picker",
    "course-booking-confirm",
    "course-booking-material-warning",
    "inventory-list",
    "inventory-low-stock-section",
    "profile-sleep-threshold",
    "profile-points-rule-signin"
  ]
}
